# ============================================================
# Fashion App — Backend PRODUCTION environment template
# Copy to .env.prod and fill in.  Load it with APP_ENV=prod.
# NEVER commit the real .env.prod — only this .example.
# In real hosting you normally set these as the platform's env vars
# (Railway/Render/Fly secrets) rather than a file on disk.
# ============================================================

ENVIRONMENT=prod

# CORS: explicit origins only (no "*" outside dev — the app refuses to boot).
CORS_ORIGINS=https://your-domain.com

# ---- Supabase (your real production project) ----------------
SUPABASE_URL=https://your-prod-project-ref.supabase.co
SUPABASE_ANON_KEY=your-prod-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# ---- Later phases (leave blank for Phase 0) -----------------
PINECONE_API_KEY=
PINECONE_INDEX=
REPLICATE_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
