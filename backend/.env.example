# ============================================================
# Fashion App — Backend environment template  (DEV)
# Copy to .env and fill in.  This is the default (APP_ENV=dev).
#
# The APP_ENV variable selects which file the app loads:
#   APP_ENV=dev      -> .env          (this one; the default)
#   APP_ENV=staging  -> .env.staging  (see .env.staging.example)
#   APP_ENV=prod     -> .env.prod     (see .env.prod.example)
#
# NEVER commit the real .env files — only the .example templates.
# ============================================================

# Which environment this process is running as: dev | staging | prod
# (APP_ENV overrides this at startup, so they always agree.)
ENVIRONMENT=dev

# CORS: comma-separated list of allowed origins (the mobile app / web dev server)
# Use * only in dev.
CORS_ORIGINS=*

# ---- Supabase (Phase 0) -------------------------------------
# From Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service role key bypasses Row Level Security. Server-side ONLY. Never ship to the app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Later phases (leave blank for Phase 0) -----------------
# Phase 1/2 — vector search + ML inference
PINECONE_API_KEY=
PINECONE_INDEX=
REPLICATE_API_TOKEN=
# Phase 1 — interaction queue / cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
