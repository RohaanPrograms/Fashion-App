# ============================================================
# Fashion App — Backend STAGING environment template
# Copy to .env.staging and fill in.  Load it with APP_ENV=staging.
# NEVER commit the real .env.staging — only this .example.
# ============================================================

ENVIRONMENT=staging

# CORS: explicit origins only (no "*" outside dev — the app refuses to boot).
# List every front end that may call this API, comma-separated.
CORS_ORIGINS=https://staging.your-domain.com

# ---- Supabase (use a SEPARATE Supabase project from prod) ---
SUPABASE_URL=https://your-staging-project-ref.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# ---- Later phases (leave blank for Phase 0) -----------------
PINECONE_API_KEY=
PINECONE_INDEX=
REPLICATE_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
