# Mobile app environment template.
# Copy to `.env` (which is gitignored) and adjust as needed.
#
# Variables must start with EXPO_PUBLIC_ to be readable from app code.

# Which environment this build points at: dev | staging | prod
# Picks the matching backend URL from src/config.ts. Defaults to dev.
EXPO_PUBLIC_ENV=dev

# Optional override of the backend URL. If set, it ALWAYS wins over the
# per-environment default above. Use it to point at your computer's LAN IP
# when testing on a real phone via Expo Go, e.g. http://192.168.1.42:8000
# (run `ipconfig` on Windows to find it — look for "IPv4 Address").
# Leave commented out to use the default for EXPO_PUBLIC_ENV.
# EXPO_PUBLIC_API_URL=http://localhost:8000
